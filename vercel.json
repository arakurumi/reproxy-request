{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/api"
    },
    {
      "source": "/api/((?!$).*)",
      "destination": "/api?url=$1"
    },
    {
      "source": "/((?!api(?:/|$)).*)",
      "destination": "/api?url=$1"
    }
  ]
}
